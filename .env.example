GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id
GOOGLE_PRICES_SHEET_NAME=prices
GOOGLE_RUNS_SHEET_NAME=runs

# GitHub Personal Access Token for auto git push
# Create at: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic)
# Scope needed: repo (full control) or public_repo
GIT_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx
